---
// src/components/Intro.astro
//
// Editorial "philosophy" block. Two-column grid: a small eyebrow label
// on the left, a large serif paragraph + signature on the right.
// The paragraph body comes from site.intro.bodyHtml so words can be
// italicised (rendered tan) via <em>…</em>.

import { site } from "../config/site";

const { intro } = site;
---

<section id="intro" class="intro">
  <div class="eyebrow">{intro.eyebrow}</div>
  <div class="body">
    <p set:html={intro.bodyHtml}></p>
    <div class="sig">
      <span class="swirl">{intro.signatureName}</span>
      <span class="role">{intro.signatureRole}</span>
    </div>
  </div>
</section>

<style>
  .intro {
    padding: 112px 64px;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 80px;
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    font-weight: 500;
    padding-top: 16px;
  }

  .body p {
    font-family: var(--font-serif);
    font-size: 28px;
    line-height: 1.4;
    letter-spacing: -0.005em;
    font-weight: 400;
    color: var(--color-forest);
  }
  .body p :global(em) {
    font-style: normal;
    color: var(--color-tan);
  }

  .sig {
    margin-top: 36px;
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    font-size: 13px;
    color: var(--color-ink-soft);
  }
  .sig .swirl {
    font-family: var(--font-serif);
    font-size: 20px;
    font-style: normal;
    color: var(--color-forest);
    font-weight: 400;
  }

  @media (max-width: 900px) {
    .intro {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 64px 24px;
    }
    .body p { font-size: 22px; }
    .sig .swirl { font-size: 18px; }
  }
</style>
