---
// src/components/Testimonials.astro
//
// "Quiet proof" testimonials. Two columns on desktop:
//   • Left rail (sticky) — eyebrow, heading, star rating + review count.
//   • Right column — vertical stack of quote cards, each with a tan
//     curly-quote ornament, avatar dot, and patient meta.
// Stacks to one column under 900px.

import { site } from "../config/site";

const { testimonials } = site;
---

<section id="testimonials" class="testi">
  <aside class="testi-left">
    <div class="eyebrow">{testimonials.eyebrow}</div>
    <h2 set:html={testimonials.headingHtml}></h2>
    <div class="stars">
      <span class="stars-row" aria-label="5 iš 5">★★★★★</span>
      <span class="rating">{testimonials.rating} iš {testimonials.reviewCount} atsiliepimų</span>
    </div>
  </aside>

  <div class="testi-list">
    {testimonials.items.map((t) => (
      <article class="quote">
        <p>{t.quote}</p>
        <div class="who">
          <span class="av" aria-hidden="true"></span>
          <span class="meta">
            <strong>{t.name}</strong>
            {t.role}
          </span>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .testi {
    padding: 140px 64px;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 80px;
    align-items: start;
  }

  .testi-left { position: sticky; top: 40px; }

  .eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    font-weight: 500;
    margin-bottom: 16px;
  }

  .testi-left h2 {
    font-family: var(--font-serif);
    font-size: 56px;
    letter-spacing: -0.03em;
    line-height: 1;
    font-weight: 400;
    color: var(--color-forest);
  }
  .testi-left h2 :global(em) {
    font-style: italic;
    color: var(--color-tan);
  }

  .stars {
    margin-top: 32px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .stars-row {
    color: var(--color-tan);
    letter-spacing: 4px;
    font-size: 18px;
  }
  .rating {
    font-family: var(--font-serif);
    font-size: 14px;
    font-style: italic;
    color: var(--color-ink-soft);
  }

  .testi-list {
    display: flex;
    flex-direction: column;
    gap: 36px;
  }
  .quote {
    border-top: 1px solid var(--color-line);
    padding-top: 36px;
  }
  .quote p {
    font-family: var(--font-serif);
    font-size: 28px;
    line-height: 1.32;
    letter-spacing: -0.01em;
    color: var(--color-forest);
    font-weight: 400;
  }
  .quote p::before {
    content: "“";
    font-size: 1.4em;
    line-height: 0;
    vertical-align: -0.2em;
    color: var(--color-tan);
    margin-right: 4px;
  }
  .quote p::after {
    content: "”";
    color: var(--color-tan);
  }

  .quote .who {
    margin-top: 24px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .quote .who .av {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--color-cream);
    flex-shrink: 0;
  }
  .quote .who .meta {
    font-size: 13px;
    color: var(--color-ink-soft);
  }
  .quote .who .meta strong {
    color: var(--color-ink);
    font-weight: 500;
    display: block;
    font-family: var(--font-serif);
    font-size: 15px;
  }

  @media (max-width: 900px) {
    .testi {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 80px 24px;
    }
    .testi-left { position: static; }
    .testi-left h2 { font-size: 40px; }
    .quote p { font-size: 22px; }
  }
</style>
