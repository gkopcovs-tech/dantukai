---
// src/components/Testimonials.astro
//
// Customer testimonials in a 3-column grid (1 on mobile, 3 on desktop).
// Star count rendered from t.rating using Array.from.

import { site } from "../config/site";
---

<section id="testimonials" class="py-20 px-4 bg-background">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-text">
        {site.testimonials.heading}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {site.testimonials.items.map((t) => (
        <article class="bg-surface border border-border rounded-xl p-6 flex flex-col">
          <div class="flex gap-1 mb-4 text-accent" aria-label={`${t.rating} of 5 stars`}>
            {Array.from({ length: t.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>
          <blockquote class="text-text/80 leading-relaxed mb-6 flex-grow">
            "{t.quote}"
          </blockquote>
          <footer class="border-t border-border pt-4">
            <div class="font-semibold text-text">{t.name}</div>
            <div class="text-sm text-text/60">{t.role}</div>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>