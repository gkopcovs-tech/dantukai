---
// src/components/Booking.astro
//
// Booking section — REPLACES the old Contact.astro visually but keeps
// the exact same Web3Forms backend integration.
//
// HOW WEB3FORMS WORKS (unchanged from the old Contact.astro):
// 1. You sign up at web3forms.com and they give you an "access key".
// 2. The form POSTs to https://api.web3forms.com/submit with that key.
// 3. Web3Forms validates and emails you the form contents.
// 4. No backend code needed.
//
// The access key is read from PUBLIC_WEB3FORMS_KEY in .env (and in
// Cloudflare Pages env vars for production). Step 8 of the build covered
// creating that .env file.
//
// Left side: heading + intro + info blocks (address, hours, phone, email).
// Right side: editorial form with serif labels and underlined inputs.

import { site } from "../config/site";

const { booking, address } = site;
// Env var wins if set (per-client/dashboard override); otherwise fall back to
// the committed public key in site.ts so the build is self-contained.
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY || site.web3formsKey;
---

<section id="booking" class="booking">
 <div class="booking-grid">
  <!-- ── Left: heading + clinic info ── -->
  <div class="booking-left">
    <div class="eyebrow">{booking.eyebrow}</div>
    <h2 set:html={booking.headingHtml}></h2>
    <p>{booking.description}</p>

    <div class="infos">
      <div class="info">
        <div class="eyebrow">Darbo laikas</div>
        <div class="v" style="white-space: pre-line;">{site.openingHoursShort}</div>
      </div>
      <div class="info">
        <div class="eyebrow">Adresas</div>
        <div class="v">
          {address.street}<br />
          {address.postalCode} {address.city}
        </div>
      </div>
      <div class="info">
        <div class="eyebrow">Telefonas</div>
        <div class="v">
          <a href={`tel:${site.phoneRaw}`}>{site.phone}</a>
        </div>
      </div>
      <div class="info">
        <div class="eyebrow">El. paštas</div>
        <div class="v">
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </div>
      </div>
    </div>

    <!-- Interactive map fills the space under the contact details,
         beside the form ("Čia mus rasite"). -->
    {site.mapEmbedUrl && (
      <div class="booking-map">
        <div class="eyebrow">{site.contact.mapHeading}</div>
        <div class="map-frame">
          <iframe
            src={site.mapEmbedUrl}
            title={`${site.businessName} — ${address.street}, ${address.city}`}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    )}
  </div>

  <!-- ── Right: the form ── -->
  <form id="booking-form" class="form">
    <h3>Pasirinkite norimą paslaugą.</h3>

    <!-- Hidden: Web3Forms access key + email subject + honeypot -->
    <input type="hidden" name="access_key" value={accessKey} />
    <input
      type="hidden"
      name="subject"
      value={`Nauja užklausa iš ${site.businessName} svetainės`}
    />
    <input
      type="checkbox"
      name="botcheck"
      class="honeypot"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
    />

    <div class="field">
      <label for="service">Paslauga</label>
      <select id="service" name="service" required>
        {booking.serviceOptions.map((opt) => (
          <option value={opt}>{opt}</option>
        ))}
      </select>
    </div>

    <div class="field">
      <label for="doctor">Specialistas</label>
      <select id="doctor" name="doctor">
        {booking.doctorOptions.map((opt) => (
          <option value={opt}>{opt}</option>
        ))}
      </select>
    </div>

    <div class="row2">
      <div class="field">
        <label for="name">Vardas</label>
        <input id="name" name="name" type="text" required placeholder="Jūsų vardas" />
      </div>
      <div class="field">
        <label for="phone">Telefonas</label>
        <input id="phone" name="phone" type="tel" required placeholder="+370 ..." />
      </div>
    </div>

    <div class="field">
      <label for="email">El. paštas</label>
      <input id="email" name="email" type="email" required placeholder="vardas@pavyzdys.lt" />
    </div>

    <div class="row2">
      <div class="field">
        <label for="date">Data</label>
        <input id="date" name="date" type="date" required />
        <span class="hint">{booking.dateHint}</span>
      </div>
      <div class="field">
        <label for="time">Laikas</label>
        <select id="time" name="time" required>
          {booking.timeSlots.map((slot) => (
            <option value={slot}>{slot}</option>
          ))}
        </select>
      </div>
    </div>

    <div class="field">
      <label for="message">Žinutė (neprivaloma)</label>
      <input id="message" name="message" type="text" placeholder="trumpas komentaras" />
    </div>

    <button class="submit" type="submit">
      <span class="submit-label">{booking.submitLabel}</span>
      <span class="submitting-label" hidden>Siunčiama…</span>
      <span class="arrow">→</span>
    </button>

    <div id="booking-success" class="result success" hidden>
      {booking.successMessage}
    </div>
    <div id="booking-error" class="result error" hidden>
      {booking.errorMessage}
    </div>
  </form>
 </div>
</section>

<style>
  .booking {
    padding: 88px 64px;
    border-top: 1px solid var(--color-line);
  }
  .booking-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: stretch;
  }
  /* Left column is a flex column so the map can grow to fill the space
     under the contact details and match the form's height. */
  .booking-left {
    display: flex;
    flex-direction: column;
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    font-weight: 500;
  }

  /* ── Left column ── */
  .booking-left h2 {
    font-family: var(--font-serif);
    font-size: clamp(36px, 4.5vw, 56px);
    letter-spacing: -0.015em;
    line-height: 1.1;
    font-weight: 400;
    color: var(--color-ink);
    margin-top: 18px;
  }
  .booking-left h2 :global(em) {
    font-style: normal;
    color: inherit;
  }
  .booking-left p {
    font-size: 16px;
    color: var(--color-ink-soft);
    margin-top: 28px;
    max-width: 380px;
    line-height: 1.6;
  }

  .infos {
    margin-top: 56px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px 24px;
  }
  .info .eyebrow { margin-bottom: 8px; }
  .info .v {
    font-family: var(--font-serif);
    font-size: 20px;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }
  .info .v a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--color-line);
    transition: color 0.2s, border-color 0.2s;
  }
  .info .v a:hover {
    color: var(--color-ink-hover);
    border-color: var(--color-ink-hover);
  }

  /* ── Form (framed white card) ── */
  .form {
    background: var(--color-bg);
    border-radius: 8px;
    padding: 40px;
    border: 1px solid var(--color-line-strong);
  }

  .form h3 {
    font-family: var(--font-serif);
    font-size: 24px;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    font-weight: 400;
    margin-bottom: 28px;
  }
  .form h3 em {
    font-style: normal;
    color: inherit;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
  }
  .field label {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .field input,
  .field select {
    /* width + min-width keep long <option> labels from forcing the form
       wider than narrow phone viewports (selects can't shrink below
       their widest option otherwise). */
    width: 100%;
    min-width: 0;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--color-ink);
    padding: 10px 0;
    font-family: var(--font-serif);
    font-size: 20px;
    color: var(--color-forest);
    outline: none;
    border-radius: 0;
  }
  .field input::placeholder { color: rgba(61, 113, 42, 0.45); }
  .field input:focus,
  .field select:focus { border-bottom-color: var(--color-ink-hover); }
  .field input[type="date"] {
    -webkit-appearance: none;
    appearance: none;
    min-height: 44px;
  }
  .field .hint {
    font-size: 11px;
    color: var(--color-ink-soft);
    letter-spacing: 0.04em;
  }

  .row2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .submit {
    width: 100%;
    margin-top: 12px;
    padding: 18px 28px;
    border: none;
    background: var(--color-brand);
    color: var(--color-on-green);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.04em;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    box-shadow: var(--btn-shadow);
    transition: background 0.2s, opacity 0.2s,
                transform 0.28s var(--ease-lux), box-shadow 0.28s var(--ease-lux);
  }
  .submit:hover {
    background: var(--color-ink-hover);
    transform: translateY(-2px);
    box-shadow: var(--btn-shadow-hover);
  }
  .submit:active {
    transform: translateY(0);
    box-shadow: var(--btn-shadow-press);
  }
  .submit:focus-visible {
    outline: 2px solid var(--color-ink-hover);
    outline-offset: 3px;
  }
  .submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }
  .submit .arrow {
    font-family: var(--font-serif);
    font-style: normal;
    transition: transform 0.28s var(--ease-lux);
  }
  /* Arrow glides forward on hover — signals "send". */
  .submit:hover:not(:disabled) .arrow { transform: translateX(4px); }

  .result {
    margin-top: 20px;
    padding: 14px 18px;
    border-radius: 4px;
    font-size: 14px;
    line-height: 1.5;
  }
  /* Success = framed pale-green note; error = solid green fill. Both stay
     within the single-green palette. */
  .result.success {
    background: rgba(61, 113, 42, 0.10);
    color: var(--color-ink);
    border: 1px solid var(--color-line-strong);
  }
  .result.error {
    background: var(--color-ink);
    color: var(--color-on-green);
    border: 1px solid var(--color-ink);
  }

  /* Honeypot: visually hidden but still in the DOM */
  .honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  /* ── Interactive map (fills the left column under the contact info) ── */
  .booking-map {
    margin-top: 44px;
    flex: 1 1 auto;          /* grow to absorb the empty space */
    display: flex;
    flex-direction: column;
    min-height: 260px;
  }
  .booking-map .eyebrow { margin-bottom: 14px; }
  .map-frame {
    flex: 1 1 auto;
    min-height: 230px;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--color-line);
    line-height: 0;
  }
  .map-frame iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 900px) {
    .booking {
      padding: 64px 24px;
    }
    .booking-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .booking-left h2 { font-size: 36px; }
    .form { padding: 28px; }
    .infos { gap: 24px 18px; }
    .row2 { grid-template-columns: 1fr; }
    /* Single column: give the map an explicit height (no form to match). */
    .booking-map { margin-top: 32px; }
    .map-frame,
    .map-frame iframe { height: 300px; min-height: 0; }
  }

  @media (max-width: 500px) {
    .infos { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById("booking-form") as HTMLFormElement | null;
  const success = document.getElementById("booking-success");
  const errorBox = document.getElementById("booking-error");

  // Date picker: no past dates, no weekends (clinic works Mon–Fri).
  const dateInput = document.getElementById("date") as HTMLInputElement | null;
  if (dateInput) {
    const today = new Date();
    const pad = (n: number) => String(n).padStart(2, "0");
    dateInput.min = `${today.getFullYear()}-${pad(today.getMonth() + 1)}-${pad(today.getDate())}`;

    dateInput.addEventListener("input", () => {
      if (!dateInput.value) {
        dateInput.setCustomValidity("");
        return;
      }
      const day = new Date(`${dateInput.value}T00:00:00`).getDay();
      dateInput.setCustomValidity(
        day === 0 || day === 6
          ? "Savaitgaliais nedirbame — pasirinkite darbo dieną (I–V)."
          : ""
      );
      dateInput.reportValidity();
    });
  }

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const button = form.querySelector("button[type=submit]") as HTMLButtonElement;
      const submitLabel = button.querySelector(".submit-label") as HTMLElement | null;
      const submittingLabel = button.querySelector(".submitting-label") as HTMLElement | null;

      button.disabled = true;
      submitLabel?.setAttribute("hidden", "");
      submittingLabel?.removeAttribute("hidden");
      success?.setAttribute("hidden", "");
      errorBox?.setAttribute("hidden", "");

      const formData = new FormData(form);

      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          body: formData,
        });
        const data = await res.json();

        if (data.success) {
          success?.removeAttribute("hidden");
          form.reset();
        } else {
          errorBox?.removeAttribute("hidden");
        }
      } catch {
        errorBox?.removeAttribute("hidden");
      } finally {
        button.disabled = false;
        submitLabel?.removeAttribute("hidden");
        submittingLabel?.setAttribute("hidden", "");
      }
    });
  }
</script>
