---
// src/components/Hero.astro
//
// Top-of-page hero: eyebrow → giant multi-line serif headline (left),
// subheadline + two CTAs + meta line (right). Below it, an editorial
// image strip — two photo placeholders side-by-side with an absolutely
// positioned badge overlay. When real images are provided in site.ts
// (hero.imageLeftSrc / imageRightSrc) they replace the placeholder
// pattern; otherwise we show the labelled pill in front of a cream
// repeating-stripe pattern (matches the design mockup).

import { site } from "../config/site";

const { hero } = site;
---

<section id="hero" class="hero">
  <div class="hero-text">
    <div class="eyebrow">{hero.eyebrow}</div>
    <h1 class="headline">
      {hero.headlineLines.map((line) => (
        <span class="line" set:html={line}></span>
      ))}
    </h1>
  </div>

  <div class="hero-meta">
    <div class="hero-actions">
      <a class="pill" href={hero.primaryCtaHref}>{hero.primaryCtaLabel}</a>
      <a class="pill ghost" href={hero.secondaryCtaHref}>{hero.secondaryCtaLabel}</a>
    </div>
  </div>
</section>

<div class="hero-img">
  <div class="ph" style={hero.imageLeftSrc ? `background-image: url(${hero.imageLeftSrc});` : ""}>
    {!hero.imageLeftSrc && <span class="lbl">{hero.imageLeftLabel}</span>}
  </div>
  <div class="ph dark" style={hero.imageRightSrc ? `background-image: url(${hero.imageRightSrc});` : ""}>
    {!hero.imageRightSrc && <span class="lbl">{hero.imageRightLabel}</span>}
  </div>
  <div class="badge">
    <span class="badge-index">{hero.badgeIndex}</span>
    <span class="badge-tagline">{hero.badgeTagline}</span>
  </div>
</div>

<style>
  .eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    font-weight: 500;
    margin-bottom: 32px;
  }

  .hero {
    padding: 64px 64px 48px;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: center;
  }

  .hero .headline {
    font-family: var(--font-serif);
    font-size: clamp(40px, 5vw, 76px);
    line-height: 1.08;
    letter-spacing: -0.015em;
    font-weight: 400;
    color: var(--color-ink);
  }
  .hero .headline .line {
    display: block;
  }
  /* Emphasis stays the same colour as the rest of the headline —
     no highlighted words. */
  .hero .headline :global(em) {
    font-style: normal;
    font-weight: 400;
    color: inherit;
  }
  .hero .headline :global(.sm) {
    font-style: normal;
    color: inherit;
  }

  .hero-meta {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Two large CTAs, stacked and full-width so they fill the column that the
     old subheadline used to occupy. */
  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: stretch;
    max-width: 460px;
  }

  /* Shared pill button — enlarged hero variant. */
  .pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 22px 32px;
    border-radius: 999px;
    background: var(--color-brand);
    color: var(--color-on-green);
    font-size: 17px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.01em;
    text-align: center;
    text-decoration: none;
    box-shadow: var(--btn-shadow);
    transition: background 0.2s, color 0.2s, border-color 0.2s,
                transform 0.28s var(--ease-lux), box-shadow 0.28s var(--ease-lux);
  }
  /* Lift on hover, press back down on click — gives the CTA a tactile,
     "physical" feel without changing colour. */
  .pill:hover {
    background: var(--color-ink-hover);
    transform: translateY(-2px);
    box-shadow: var(--btn-shadow-hover);
  }
  .pill:active {
    transform: translateY(0);
    box-shadow: var(--btn-shadow-press);
  }
  .pill:focus-visible {
    outline: 2px solid var(--color-ink-hover);
    outline-offset: 3px;
  }

  /* Secondary CTA: a quiet outline that warms with a faint green wash and
     the same lift on hover (no heavy solid invert). */
  .pill.ghost {
    background: transparent;
    color: var(--color-ink);
    border: 1.5px solid var(--color-line-strong);
    box-shadow: none;
  }
  .pill.ghost:hover {
    background: rgba(61, 113, 42, 0.06);
    color: var(--color-ink-hover);
    border-color: var(--color-ink);
    transform: translateY(-2px);
    box-shadow: var(--btn-shadow);
  }
  .pill.ghost:active {
    transform: translateY(0);
    box-shadow: none;
  }

  /* ── Hero image strip ── */
  .hero-img {
    margin: 0 64px;
    height: 400px;
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-cream);
    position: relative;
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 0;
  }
  .ph {
    position: relative;
    background:
      repeating-linear-gradient(45deg, rgba(28,61,18,0.05) 0 1px, transparent 1px 14px),
      var(--color-cream);
    background-size: cover;
    background-position: center;
    display: grid;
    place-items: center;
  }
  .ph.dark {
    background:
      repeating-linear-gradient(45deg, rgba(255,255,255,0.07) 0 1px, transparent 1px 14px),
      var(--color-forest);
    background-size: cover;
    background-position: center;
  }
  .ph .lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-forest);
    opacity: 0.6;
    border: 1px solid rgba(28,61,18,0.25);
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,0.7);
  }
  .ph.dark .lbl {
    color: var(--color-bg);
    border-color: rgba(255,255,255,0.4);
    background: rgba(28,61,18,0.4);
  }

  .badge {
    position: absolute;
    top: 22px;
    left: 22px;
    right: 22px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-bg);
    mix-blend-mode: difference;
    pointer-events: none;
  }
  .badge-index {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
  }
  .badge-tagline {
    font-family: var(--font-serif);
    font-style: normal;
    font-size: 16px;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 56px 24px 48px;
      align-items: start;
    }
    .hero .headline { font-size: 46px; }
    .hero-meta p { font-size: 16px; }

    .hero-img {
      margin: 0 24px;
      height: 320px;
      grid-template-columns: 1fr;
    }
    .hero-img .ph.dark { display: none; }
    .badge-tagline { font-size: 14px; }
  }

  @media (max-width: 600px) {
    /* The long tagline would overflow the narrow single placeholder. */
    .badge-tagline { display: none; }
  }

  @media (max-width: 500px) {
    .hero .headline { font-size: 38px; }
  }
</style>
