---
import { site } from "../config/site";
---

<header class="sticky top-0 z-50 bg-background border-b border-border">
  <div class="mx-auto max-w-6xl px-4 py-3 flex items-center justify-between gap-4">
    <!-- Logo + business name -->
    <a href="/" class="flex items-center gap-2 shrink-0">
      <img src={site.logoSrc} alt={site.logoAlt} class="h-10 w-auto" />
      <span class="font-semibold text-text hidden sm:inline">{site.businessName}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6">
      {site.navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-text hover:text-primary transition"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Phone CTA (desktop only) -->
    <a
      href={`tel:${site.phoneRaw}`}
      class="hidden md:inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary text-white text-sm font-medium hover:opacity-90 transition shrink-0"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      {site.phone}
    </a>

    <!-- Mobile menu toggle (mobile only) -->
    <button
      id="mobile-menu-toggle"
      type="button"
      class="md:hidden p-2 text-text hover:text-primary transition"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu (hidden until toggled) -->
  <nav id="mobile-menu" class="md:hidden hidden border-t border-border bg-background">
    <div class="mx-auto max-w-6xl px-4 py-3 flex flex-col gap-3">
      {site.navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-text hover:text-primary transition py-2"
        >
          {link.label}
        </a>
      ))}
      <a
        href={`tel:${site.phoneRaw}`}
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary text-white text-sm font-medium hover:opacity-90 transition self-start"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {site.phone}
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = !menu.classList.toggle("hidden");
      toggle.setAttribute("aria-expanded", String(isOpen));
    });

    // Close the menu when any link inside it is clicked
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        toggle.setAttribute("aria-expanded", "false");
      });
    });
  }
</script>