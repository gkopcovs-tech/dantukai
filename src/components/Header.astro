---
// src/components/Header.astro
//
// Top navigation. Three columns on desktop: links / brand / phone + CTA.
// Collapses to brand + hamburger on mobile; the hamburger toggles a
// dropdown panel that contains the same links and the booking CTA.

import { site } from "../config/site";
---

<header class="site-nav">
  <!-- Left: section links (desktop only) -->
  <div class="nav-left">
    {site.navLinks.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
  </div>

  <!-- Center: brand mark + wordmark -->
  <a class="nav-logo" href="#top" aria-label={site.businessName}>
    <span class="mark">{site.logoMark}</span>
    <span class="name" set:html={site.businessNameHtml}></span>
  </a>

  <!-- Right: phone + booking pill (desktop) / hamburger (mobile) -->
  <div class="nav-right">
    <a class="phone" href={`tel:${site.phoneRaw}`}>{site.phone}</a>
    <a class="pill" href="#booking">Registracija →</a>
    <button
      id="nav-toggle"
      class="hamburger"
      type="button"
      aria-label="Meniu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile dropdown menu — hidden by default, toggled via JS below -->
<nav id="mobile-menu" class="mobile-menu" hidden>
  {site.navLinks.map((link) => (
    <a href={link.href}>{link.label}</a>
  ))}
  <a href={`tel:${site.phoneRaw}`}>{site.phone}</a>
  <a class="pill" href="#booking">Registracija →</a>
</nav>

<style>
  .site-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 28px 64px;
    border-bottom: 1px solid var(--color-line);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .nav-left {
    display: flex;
    gap: 36px;
    font-size: 13px;
    color: var(--color-ink-soft);
  }
  .nav-left a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-left a:hover { color: var(--color-tan); }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }
  .nav-logo .mark {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--color-forest);
    display: grid;
    place-items: center;
    color: var(--color-bg);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 15px;
    font-weight: 500;
  }
  .nav-logo .name {
    font-family: var(--font-serif);
    font-size: 18px;
    letter-spacing: -0.01em;
    font-weight: 500;
    color: var(--color-ink);
  }
  .nav-logo .name :global(em) {
    font-style: italic;
    color: var(--color-tan);
    font-weight: 400;
  }

  .nav-right {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 24px;
    font-size: 13px;
  }
  .nav-right .phone {
    color: var(--color-ink-soft);
    text-decoration: none;
  }
  .nav-right .phone:hover { color: var(--color-ink); }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 20px;
    border-radius: 999px;
    background: var(--color-forest);
    color: var(--color-bg);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s;
  }
  .pill:hover { background: #1f2a20; }

  /* Hamburger — hidden on desktop, shown on mobile */
  .hamburger {
    display: none;
    background: transparent;
    border: 0;
    padding: 8px;
    cursor: pointer;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-ink);
    margin: 5px 0;
    transition: transform 0.2s, opacity 0.2s;
  }
  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 12px 28px 24px;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-line);
  }
  .mobile-menu a {
    padding: 12px 0;
    color: var(--color-ink);
    text-decoration: none;
    font-size: 15px;
    border-bottom: 1px solid var(--color-line);
  }
  .mobile-menu a:last-child { border-bottom: 0; }
  .mobile-menu .pill {
    margin-top: 12px;
    align-self: flex-start;
  }
  .mobile-menu:not([hidden]) { display: flex; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .site-nav {
      grid-template-columns: 1fr auto;
      padding: 18px 24px;
    }
    .nav-left { display: none; }
    .nav-right .phone,
    .nav-right .pill { display: none; }
    .hamburger { display: block; }
  }
</style>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = menu.hasAttribute("hidden") ? true : false;
      if (isOpen) {
        menu.removeAttribute("hidden");
        toggle.setAttribute("aria-expanded", "true");
      } else {
        menu.setAttribute("hidden", "");
        toggle.setAttribute("aria-expanded", "false");
      }
    });

    // Close menu on any link click
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menu.setAttribute("hidden", "");
        toggle.setAttribute("aria-expanded", "false");
      });
    });
  }
</script>
