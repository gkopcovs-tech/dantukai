---
// src/components/MapEmbed.astro
//
// Google Maps iframe embed.
// URL must come from Google Maps' "Embed" share option (not a regular Maps URL).
// To generate one: Google Maps → search location → Share → "Embed a map" → copy src URL.

import { site } from "../config/site";
---

<section class="py-20 px-4 bg-background">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4 text-text">
        {site.contact.mapHeading}
      </h2>
      <p class="text-lg text-text/70">
        {site.address.street}, {site.address.postalCode} {site.address.city}
      </p>
    </div>

    <div class="rounded-2xl overflow-hidden border border-border shadow-lg">
      <iframe
        src={site.mapEmbedUrl}
        width="100%"
        height="450"
        style="border:0;"
        loading="lazy"
        allowfullscreen
        referrerpolicy="no-referrer-when-downgrade"
        title={`Map showing ${site.businessName}`}
      ></iframe>
    </div>
  </div>
</section>