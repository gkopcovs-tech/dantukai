---
// src/components/Faq.astro
//
// Accordion FAQ on a soft-beige background. Two-column layout on desktop:
// left has the eyebrow + heading + helper sentence with contact email;
// right has the list of expandable items. Native <button> + aria-expanded
// for accessibility; a tiny inline script toggles open state.
// The first item starts open so visitors see one answer for free.

import { site } from "../config/site";

const { faq } = site;
---

<section id="faq" class="faq">
  <div class="faq-grid">
    <div class="faq-head">
      <div class="eyebrow">{faq.eyebrow}</div>
      <h2 set:html={faq.headingHtml}></h2>
      <p class="helper" set:html={faq.helperHtml}></p>
      <a class="helper-email" href={`mailto:${site.email}`}>{site.email}</a>

      <!-- Photo fills the empty space beside the question list. -->
      <div class="faq-photo">
        <span class="lbl">[ FOTO · Ozodenta klinika ]</span>
      </div>
    </div>

    <div class="faq-list">
      {faq.items.map((item, i) => (
        <div class={`faq-item ${i === 0 ? "open" : ""}`}>
          <button
            class="row"
            type="button"
            aria-expanded={i === 0 ? "true" : "false"}
          >
            <span class="q">{item.question}</span>
            <span class="plus" aria-hidden="true">+</span>
          </button>
          <div class="a" hidden={i !== 0}>{item.answer}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faq {
    background: var(--color-bg);
    padding: 88px 64px;
    border-top: 1px solid var(--color-line);
  }

  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 64px;
    align-items: stretch;
  }
  /* Left column flexes so the photo grows to match the question list. */
  .faq-head {
    display: flex;
    flex-direction: column;
  }
  .faq-photo {
    margin-top: 40px;
    flex: 1 1 auto;
    min-height: 220px;
    border-radius: 6px;
    overflow: hidden;
    background:
      repeating-linear-gradient(45deg, rgba(28,61,18,0.05) 0 1px, transparent 1px 14px),
      var(--color-cream);
    display: grid;
    place-items: center;
  }
  .faq-photo .lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-forest);
    opacity: 0.6;
    border: 1px solid rgba(28, 61, 18, 0.25);
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.7);
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    font-weight: 500;
  }

  .faq-head h2 {
    font-family: var(--font-serif);
    font-size: clamp(32px, 3.6vw, 48px);
    letter-spacing: -0.015em;
    line-height: 1.12;
    font-weight: 400;
    color: var(--color-ink);
    margin-top: 18px;
  }
  .faq-head h2 :global(em) {
    font-style: normal;
    color: inherit;
  }
  .helper {
    font-size: 14px;
    color: var(--color-ink-soft);
    margin-top: 24px;
    max-width: 340px;
    line-height: 1.55;
  }
  /* Email sits on its own line under the helper sentence, left-aligned with
     it — keeps the contact line tidy instead of dangling inline. */
  .helper-email {
    display: inline-block;
    margin-top: 8px;
    font-size: 14px;
    color: var(--color-ink);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid var(--color-line);
    transition: color 0.2s, border-color 0.2s;
  }
  .helper-email:hover {
    color: var(--color-ink-hover);
    border-color: var(--color-ink-hover);
  }

  .faq-list { border-top: 1px solid var(--color-line); }

  .faq-item {
    border-bottom: 1px solid var(--color-line);
  }
  .faq-item .row {
    width: 100%;
    background: transparent;
    border: 0;
    padding: 28px 0;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    text-align: left;
    color: inherit;
    font: inherit;
  }
  .faq-item .q {
    font-family: var(--font-serif);
    font-size: 19px;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    font-weight: 400;
  }
  .faq-item .plus {
    font-family: var(--font-serif);
    font-size: 28px;
    color: var(--color-ink-soft);
    font-weight: 300;
    transition: transform 0.2s, color 0.2s;
    flex-shrink: 0;
  }
  .faq-item.open .plus {
    transform: rotate(45deg);
    color: var(--color-tan);
  }
  .faq-item .a {
    font-size: 14px;
    color: var(--color-ink-soft);
    line-height: 1.6;
    max-width: 620px;
    padding: 0 0 28px 0;
  }

  @media (max-width: 900px) {
    .faq { padding: 72px 24px; }
    .faq-grid { grid-template-columns: 1fr; gap: 40px; }
    .faq-head h2 { font-size: 32px; }
    .faq-item .q { font-size: 17px; }
    .faq-photo { display: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLDivElement>(".faq-item").forEach((item) => {
    const button = item.querySelector<HTMLButtonElement>(".row");
    const answer = item.querySelector<HTMLDivElement>(".a");
    if (!button || !answer) return;

    button.addEventListener("click", () => {
      const isOpen = item.classList.toggle("open");
      button.setAttribute("aria-expanded", isOpen ? "true" : "false");
      if (isOpen) {
        answer.removeAttribute("hidden");
      } else {
        answer.setAttribute("hidden", "");
      }
    });
  });
</script>
