---
// src/components/About.astro
//
// About section: heading + paragraph + image, side-by-side on desktop.

import { site } from "../config/site";
---

<section id="about" class="py-20 px-4 bg-surface">
  <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <div>
      <h2 class="text-3xl sm:text-4xl font-bold mb-6 text-text">
        {site.about.heading}
      </h2>
      <p class="text-lg text-text/80 leading-relaxed">
        {site.about.body}
      </p>
    </div>
    <div class="order-first lg:order-last">
      <img
        src={site.about.image}
        alt={site.about.heading}
        class="w-full h-auto rounded-2xl shadow-xl"
        loading="lazy"
        width="800"
        height="600"
      />
    </div>
  </div>
</section>