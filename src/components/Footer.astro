---
// src/components/Footer.astro
//
// Three-column footer: brand+address, opening hours, social links.
// Social icons live in the frontmatter as raw SVG strings and are
// injected via <Fragment set:html={...} />.

import { site } from "../config/site";

// To add a new social platform later: add a key here matching the
// `platform` field used in site.socialLinks, plus the icon SVG.
const socialIcons: Record<string, string> = {
  facebook:
    '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12S0 5.417 0 12.044c0 5.628 3.874 10.35 9.101 11.647Z"/></svg>',
  instagram:
    '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>',
};
---

<footer class="bg-surface border-t border-border mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Column 1: Brand + address -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src={site.logoSrc} alt={site.logoAlt} class="h-8 w-auto" width="32" height="32" />
          <span class="font-semibold text-lg text-primary">{site.businessName}</span>
        </div>
        <p class="text-sm text-text/70 mb-4">{site.tagline}</p>
        <address class="not-italic text-sm text-text/80 space-y-1">
          <div>{site.address.street}</div>
          <div>{site.address.postalCode} {site.address.city}</div>
          <div>{site.address.country}</div>
          <div class="pt-2">
            <a href={`tel:${site.phoneRaw}`} class="hover:text-primary transition">
              {site.phone}
            </a>
          </div>
          <div>
            <a href={`mailto:${site.email}`} class="hover:text-primary transition">
              {site.email}
            </a>
          </div>
        </address>
      </div>

      <!-- Column 2: Opening hours -->
      <div>
        <h3 class="font-semibold text-text mb-4">Darbo laikas</h3>
        <ul class="text-sm text-text/80 space-y-2">
          {site.openingHours.map((row) => (
            <li class="flex justify-between gap-4">
              <span>{row.day}</span>
              <span class="text-text/60">{row.hours}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Social -->
      <div>
        <h3 class="font-semibold text-text mb-4">Sekite mus</h3>
        <ul class="flex gap-3">
          {site.socialLinks.map((social) => (
            <li>
             <a 
                href={social.url}
                aria-label={social.label}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-border text-text hover:text-primary hover:border-primary transition"
              >
                <Fragment set:html={socialIcons[social.platform] || ""} />
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-border mt-10 pt-6 text-center text-sm text-text/60">
      {site.copyright}
    </div>
  </div>
</footer>