---
// src/components/Footer.astro
//
// Dark forest footer with four columns on desktop:
//   1. Brand wordmark + small tagline
//   2. Visit address
//   3. Site link list (Klinika)
//   4. Contact links (phone / email / social)
// Stacks vertically on mobile.

import { site } from "../config/site";

const { footer, address } = site;
---

<footer class="site-footer">
  <div class="top">
    <div class="brand-col">
      <div class="brand" set:html={site.businessNameHtml + '<span class="dot">.</span>'}></div>
      <p class="tag">{footer.brandTagline}</p>
    </div>

    <div>
      <h4>{footer.visitHeading}</h4>
      <div class="addr">
        {address.street}<br />
        {address.postalCode} {address.city}<br />
        {address.floorNote}
      </div>
    </div>

    {footer.linkColumns.map((col) => (
      <div>
        <h4>{col.heading}</h4>
        <ul>
          {col.items.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="bottom">
    <span>{site.copyright}</span>
    <span>{footer.legalNote}</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-forest);
    color: var(--color-bg);
    padding: 96px 64px 40px;
  }

  .top {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 64px;
    border-bottom: 1px solid rgba(244, 239, 232, 0.15);
  }

  h4 {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(244, 239, 232, 0.5);
    font-weight: 500;
    margin-bottom: 20px;
  }

  .brand {
    font-family: var(--font-serif);
    font-size: 56px;
    letter-spacing: -0.03em;
    line-height: 1;
    font-weight: 400;
  }
  .brand :global(em) {
    font-style: italic;
    color: var(--color-tan);
  }
  .brand :global(.dot) { color: var(--color-tan); }

  .tag {
    font-family: var(--font-sans);
    font-size: 13px;
    color: rgba(244, 239, 232, 0.6);
    letter-spacing: 0.02em;
    display: block;
    margin-top: 18px;
    max-width: 320px;
    line-height: 1.5;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-size: 14px;
    color: rgba(244, 239, 232, 0.8);
  }
  ul a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  ul a:hover { color: var(--color-tan); }

  .addr {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.5;
    font-style: italic;
    color: rgba(244, 239, 232, 0.9);
  }

  .bottom {
    padding-top: 32px;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 11px;
    color: rgba(244, 239, 232, 0.5);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .site-footer { padding: 64px 24px 32px; }
    .top {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      padding-bottom: 40px;
    }
    .brand-col { grid-column: 1 / -1; }
    .brand { font-size: 40px; }
  }

  @media (max-width: 500px) {
    .top { grid-template-columns: 1fr; }
  }
</style>
