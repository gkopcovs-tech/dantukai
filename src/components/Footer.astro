---
// src/components/Footer.astro
//
// Minimal, centred footer with a single "Kontaktai" group:
// address, phone and email. Stacks naturally on mobile.

import { site } from "../config/site";

const { footer, address, phone, phoneRaw, email } = site;

const addressLine = [address.street, address.city].filter(Boolean).join(", ");
---

<footer class="site-footer">
  <div class="top">
    <div class="col">
      <h4>Kontaktai</h4>
      <ul>
        <li class="addr-item">{addressLine}</li>
        <li><a href={`tel:${phoneRaw}`}>{phone}</a></li>
        <li><a href={`mailto:${email}`}>{email}</a></li>
      </ul>
    </div>
  </div>

  <div class="bottom">
    <span>{site.copyright}</span>
    <span>{footer.legalNote}</span>
  </div>
</footer>

<style>
  /* Centred, minimal footer — symmetry + generous whitespace for a quiet,
     luxury close. No brand wordmark; the three contact groups sit centred. */
  .site-footer {
    background: var(--color-bg);
    color: var(--color-ink);
    padding: 96px 64px 48px;
    border-top: 1px solid var(--color-line-strong);
    text-align: center;
  }

  .top {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 56px 104px;
    padding-bottom: 64px;
    border-bottom: 1px solid var(--color-line);
  }
  .col {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  h4 {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    font-weight: 500;
    margin-bottom: 22px;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    font-size: 14px;
    color: var(--color-ink);
  }
  ul a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  ul a:hover { color: var(--color-ink-hover); }

  .addr-item {
    color: var(--color-ink-soft);
  }

  .bottom {
    padding-top: 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    color: var(--color-ink-soft);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .site-footer { padding: 72px 24px 36px; }
    .top {
      gap: 40px 56px;
      padding-bottom: 44px;
    }
  }
</style>
