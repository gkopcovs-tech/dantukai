---
// src/components/Services.astro
//
// Editorial services list — one row per service, each row a 5-column
// grid: num / name / description / price / arrow.
// The whole row is an anchor so the entire surface is clickable.
// On hover the row shifts inward slightly and tints — same micro-interaction
// as the design mockup.
//
// Mobile (<900px): rows collapse to a single column with the num + arrow
// floating in a small top-row and the rest stacked underneath.

import { site } from "../config/site";

const { services } = site;
const total = services.items.length.toString().padStart(2, "0");
---

<section id="services" class="services">
  <header class="services-head">
    <h2 set:html={services.headingHtml}></h2>
    <p>{services.subheading}</p>
  </header>

  <div class="svc-list">
    {services.items.map((service) => (
      <a class="svc" href={service.href}>
        <span class="num">{service.num} / {total}</span>
        <span class="name" set:html={service.nameHtml}></span>
        <span class="desc">{service.description}</span>
        <span class="price">
          {service.price}
          <span class="unit">{service.priceUnit}</span>
        </span>
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    ))}
  </div>
</section>

<style>
  .services {
    padding: 72px 64px 88px;
  }

  .services-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: end;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--color-line);
  }
  .services-head h2 {
    font-family: var(--font-serif);
    font-size: clamp(34px, 4vw, 52px);
    letter-spacing: -0.015em;
    line-height: 1.1;
    font-weight: 400;
    color: var(--color-ink);
  }
  .services-head h2 :global(em) {
    font-style: normal;
    color: inherit;
    font-weight: 400;
  }
  .services-head p {
    font-size: 16px;
    max-width: 420px;
    color: var(--color-ink-soft);
    justify-self: end;
  }

  .svc-list { display: grid; grid-template-columns: 1fr; }

  .svc {
    display: grid;
    grid-template-columns: 80px 1.2fr 2fr 1fr 60px;
    padding: 36px 0;
    border-bottom: 1px solid var(--color-line);
    align-items: center;
    gap: 32px;
    text-decoration: none;
    color: inherit;
    transition: padding 0.2s, background 0.2s;
  }
  .svc:hover {
    padding-left: 16px;
    padding-right: 16px;
    background: rgba(61, 113, 42, 0.07);
  }

  .svc .num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-soft);
    letter-spacing: 0.1em;
  }
  .svc .name {
    font-family: var(--font-serif);
    font-size: 23px;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    font-weight: 400;
  }
  .svc .name :global(em) {
    font-style: normal;
    color: inherit;
  }
  .svc .desc {
    font-size: 14px;
    color: var(--color-ink-soft);
    line-height: 1.55;
    max-width: 380px;
  }
  .svc .price {
    font-family: var(--font-serif);
    font-size: 18px;
    color: var(--color-ink);
    font-style: normal;
  }
  .svc .price .unit {
    font-size: 11px;
    font-family: var(--font-sans);
    color: var(--color-ink-soft);
    font-style: normal;
    display: block;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .svc .arrow {
    font-size: 22px;
    color: var(--color-ink-soft);
    text-align: right;
    font-family: var(--font-serif);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .services { padding: 56px 24px 80px; }

    .services-head {
      grid-template-columns: 1fr;
      gap: 24px;
      padding-bottom: 32px;
    }
    .services-head h2 { font-size: 34px; }
    .services-head p { justify-self: start; }

    .svc {
      grid-template-columns: 1fr auto;
      gap: 12px 16px;
      padding: 28px 0;
    }
    .svc:hover { padding-left: 12px; padding-right: 12px; }
    .svc .num { grid-column: 1; }
    .svc .arrow { grid-column: 2; grid-row: 1; }
    .svc .name { grid-column: 1 / -1; font-size: 21px; }
    .svc .desc { grid-column: 1 / -1; }
    .svc .price { grid-column: 1 / -1; }
  }
</style>
