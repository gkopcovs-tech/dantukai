---
// src/components/Contact.astro
//
// Contact form using Web3Forms.
//
// HOW WEB3FORMS WORKS:
// 1. You sign up at web3forms.com — they give you an "access key"
// 2. The form POSTs to https://api.web3forms.com/submit with the access key
// 3. Web3Forms validates and emails you the form contents
// 4. No backend code needed — it's all client-side fetch() + their service
//
// The access key is loaded from PUBLIC_WEB3FORMS_KEY in the .env file.
// Step 8 of the build will walk through creating .env and setting it up
// in Cloudflare Pages for production.

import { site } from "../config/site";

const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<section id="contact" class="py-20 px-4 bg-surface">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4 text-text">
        {site.contact.heading}
      </h2>
      <p class="text-lg text-text/70">
        {site.contact.subheading}
      </p>
    </div>

    <form id="contact-form" class="bg-background border border-border rounded-xl p-6 sm:p-8 space-y-5">
      <!-- Access key: public, identifies the Web3Forms account that receives submissions -->
      <input type="hidden" name="access_key" value={accessKey} />

      <!-- Subject line for the email Web3Forms sends you -->
      <input
        type="hidden"
        name="subject"
        value={`Naujas užklausimas iš ${site.businessName} svetainės`}
      />

      <!-- Honeypot: hidden from users, only bots fill it. Web3Forms drops submissions with a value here. -->
      <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="name" class="block text-sm font-medium text-text mb-1">
            Vardas <span class="text-accent">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-2.5 rounded-lg border border-border bg-background text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-text mb-1">
            El. paštas <span class="text-accent">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2.5 rounded-lg border border-border bg-background text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition"
          />
        </div>
      </div>

      <div>
        <label for="phone" class="block text-sm font-medium text-text mb-1">Telefonas</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          class="w-full px-4 py-2.5 rounded-lg border border-border bg-background text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-text mb-1">
          Žinutė <span class="text-accent">*</span>
        </label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full px-4 py-2.5 rounded-lg border border-border bg-background text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full bg-primary text-white font-semibold py-3 rounded-lg hover:opacity-90 transition disabled:opacity-50 disabled:cursor-not-allowed"
      >
        <span class="submit-label">Siųsti žinutę</span>
        <span class="submitting-label hidden">Siunčiama...</span>
      </button>

      <div id="form-success" class="hidden text-center p-4 bg-primary/10 text-primary rounded-lg">
        Ačiū! Jūsų žinutė išsiųsta. Susisieksime per vieną darbo dieną.
      </div>
      <div id="form-error" class="hidden text-center p-4 bg-red-100 text-red-700 rounded-lg">
        Nepavyko išsiųsti žinutės. Pabandykite dar kartą arba paskambinkite mums.
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const success = document.getElementById("form-success");
  const errorBox = document.getElementById("form-error");

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const button = form.querySelector("button[type=submit]") as HTMLButtonElement;
      const submitLabel = button.querySelector(".submit-label");
      const submittingLabel = button.querySelector(".submitting-label");

      // Show loading state
      button.disabled = true;
      submitLabel?.classList.add("hidden");
      submittingLabel?.classList.remove("hidden");
      success?.classList.add("hidden");
      errorBox?.classList.add("hidden");

      const formData = new FormData(form);

      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          body: formData,
        });
        const data = await res.json();

        if (data.success) {
          success?.classList.remove("hidden");
          form.reset();
        } else {
          errorBox?.classList.remove("hidden");
        }
      } catch {
        errorBox?.classList.remove("hidden");
      } finally {
        button.disabled = false;
        submitLabel?.classList.remove("hidden");
        submittingLabel?.classList.add("hidden");
      }
    });
  }
</script>