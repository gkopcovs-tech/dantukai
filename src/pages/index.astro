---
// src/pages/index.astro
//
// The single landing page. Composes the editorial sections in order.
// Header + Footer come from Layout.astro automatically.

import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Ticker from "../components/Ticker.astro";
import Intro from "../components/Intro.astro";
import Services from "../components/Services.astro";
import Doctors from "../components/Doctors.astro";
import Testimonials from "../components/Testimonials.astro";
import Faq from "../components/Faq.astro";
import Booking from "../components/Booking.astro";
---

<Layout>
  <Hero />
  <Ticker />
  <Intro />
  <Services />
  <Doctors />
  <Testimonials />
  <Faq />
  <Booking />
</Layout>
